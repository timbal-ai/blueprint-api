PORT=3000
NODE_ENV=development

TIMBAL_PROJECT_ID=

# Optional: override public https origin for channel webhooks (Telegram setWebhook).
# On Timbal hosts the SDK derives https://e{TIMBAL_PROJECT_ENV_ID}.{domain}/api —
# you usually don't need this. Local: set to your tunnel URL, or leave unset to
# let the SDK probe ngrok.
# PUBLIC_ORIGIN=https://xxxx.ngrok-free.app

# The following can be configured using: timbal configure --profile <PROFILE_NAME>
# - TIMBAL_ORG_ID
# - TIMBAL_API_KEY (for auth in local development)
# - TIMBAL_API_BASE_URL